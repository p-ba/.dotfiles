{
    "$schema": "https://opencode.ai/config.json",
    "lsp": false,
    "plugins": [
        "./plugins/cmux-notify.ts"
    ],
    "permissions": [
        {
            "action": "*",
            "resource": "*",
            "effect": "allow"
        }
    ],
    "mcp": {
        "servers": {
            "playwright": {
                "type": "local",
                "command": [
                    "npx",
                    "@playwright/mcp@0.0.78"
                ],
                "disabled": true
            }
        }
    }
}
